# Copy to .env and fill in. Never commit the real .env.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Browser Use LLM key (OpenAI) — required for real searches.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# false -> visible Chrome windows drive the sites (you watch the agents work)
BROWSER_HEADLESS=false
# how many real browser agents run at once
REAL_CONCURRENCY=2

# Optional: Browserbase hosted stealth browser + live-view iframe in the UI.
# If both are set, the agent uses Browserbase instead of local cloakbrowser.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_SOLVE_CAPTCHAS=true
BROWSERBASE_PROXIES=false
